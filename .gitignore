# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# --- Secrets & local config (public repo) ---
.env
.env.*
!.env.example

# Android (machine-specific SDK path; may contain local paths)
**/local.properties

# Android release signing
**/key.properties
*.jks
*.keystore

# Firebase / Google Services (download from Firebase Console or run `flutterfire configure`)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# iOS / macOS user-specific Xcode data
**/xcuserdata/

# Certificates / provisioning (if ever added locally)
*.mobileprovision
*.p12
*.pem
